{
  "name": "securevote-blockchain-evoting",
  "version": "1.0.0",
  "description": "SecureVote - Blockchain-Based Electronic Voting System MVP",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "demo": "node start-demo.js",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules",
    "install:all": "npm install",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "contracts:compile": "npm run compile --workspace=apps/contracts",
    "contracts:test": "npm run test --workspace=apps/contracts",
    "contracts:deploy": "npm run deploy --workspace=apps/contracts",
    "backend:dev": "npm run dev --workspace=apps/backend",
    "backend:build": "npm run build --workspace=apps/backend",
    "mobile:start": "npm run start --workspace=apps/mobile",
    "audit-portal:dev": "npm run dev --workspace=apps/audit-portal"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
