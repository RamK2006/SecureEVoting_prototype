# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="file:./data/securevote.db"

# JWT Configuration
JWT_SECRET=demo-secret-key-change-in-production-2024
JWT_EXPIRES_IN=24h

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
VOTER_REGISTRY_ADDRESS=
VOTE_LEDGER_ADDRESS=
ELECTION_MANAGER_ADDRESS=

# Crypto Configuration
SYSTEM_SALT=demo-system-salt-change-in-production-2024
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
VOTE_RATE_LIMIT_MAX=5

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:19006

# Security
BCRYPT_ROUNDS=12
TOKEN_TTL_MINUTES=30
REVOTING_WINDOW_MINUTES=30

# Logging
LOG_LEVEL=info